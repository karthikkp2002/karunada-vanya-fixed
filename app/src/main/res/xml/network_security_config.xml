<?xml version="1.0" encoding="utf-8"?>
<!--
    Network Security Config for Karunada-Vanya
    ──────────────────────────────────────────
    • Cleartext (HTTP) traffic is blocked globally — all CDN and Firebase
      resources use HTTPS, so this is safe.
    • The trusted anchors entry below keeps the default system CAs so that
      HTTPS connections to gstatic.com, googleapis.com, firebase, and
      cdnjs.cloudflare.com work correctly.
-->
<network-security-config>
    <base-config cleartextTrafficPermitted="false">
        <trust-anchors>
            <certificates src="system" />
        </trust-anchors>
    </base-config>
</network-security-config>
