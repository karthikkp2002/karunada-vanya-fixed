<?xml version="1.0" encoding="utf-8"?>
<resources>

    <!-- Base application theme — no action bar, dark status bar -->
    <style name="Theme.KarunadaVanyaa" parent="Theme.AppCompat.NoActionBar">
        <!-- Dark green background matching the HTML app -->
        <item name="android:windowBackground">@color/app_bg</item>
        <!-- Dark status bar background -->
        <item name="android:statusBarColor">@color/app_bg</item>
        <!-- Dark navigation bar background -->
        <item name="android:navigationBarColor">@color/app_bg</item>
        <!-- Keep status bar icons WHITE (light) — background is very dark -->
        <item name="android:windowLightStatusBar">false</item>
        <!-- Keep navigation bar icons WHITE (light) — background is very dark -->
        <item name="android:windowLightNavigationBar">false</item>
    </style>

</resources>
